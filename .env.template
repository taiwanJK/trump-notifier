TRUTHSOCIAL_USERNAME=your_truthsocial_username_here
TRUTHSOCIAL_PASSWORD=your_truthsocial_password_here
TRUTHSOCIAL_TOKEN=your_truthsocial_token_here

# 用於指定要查詢的 Truth Social 使用者帳號（通常是 Trump）
TRUTHSOCIAL_SEARCH_USERNAME=realDonaldTrump

# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID（頻道或群組的 ID，若是頻道請加上 -100）
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# HTTP 代理設定（若需要通過代理連接網路）
HTTP_PROXY_ENABLED=false
HTTP_PROXY_HOST=your_proxy_host
HTTP_PROXY_PORT=your_proxy_port
HTTP_PROXY_USERNAME=your_proxy_username
HTTP_PROXY_PASSWORD=your_proxy_password

# OpenRouter API Key（從 OpenRouter 取得）
OPENROUTER_API_KEY=your_openrouter_api_key_here

CURRENT_NEWS_API_KEY=your_current_news_api_key_here